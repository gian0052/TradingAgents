# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
DASHSCOPE_CN_API_KEY=
ZHIPU_API_KEY=
ZHIPU_CN_API_KEY=
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
OPENROUTER_API_KEY=

# Optional: point at a remote Ollama server. When unset, defaults to
# the local instance at http://localhost:11434/v1. Convention follows
# the broader Ollama ecosystem; both the CLI dropdown and programmatic
# client pick this up.
#OLLAMA_BASE_URL=http://your-ollama-host:11434/v1

# Optional: override DEFAULT_CONFIG without editing code.
# Any TRADINGAGENTS_* variable below, when set, replaces the matching key
# in tradingagents/default_config.py. Values are coerced to the type of
# the existing default (bool / int / str), so "true"/"3" work as expected.
#TRADINGAGENTS_LLM_PROVIDER=openai
#TRADINGAGENTS_DEEP_THINK_LLM=gpt-5.4
#TRADINGAGENTS_QUICK_THINK_LLM=gpt-5.4-mini
#TRADINGAGENTS_LLM_BACKEND_URL=
#TRADINGAGENTS_OUTPUT_LANGUAGE=English
#TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
#TRADINGAGENTS_MAX_RISK_ROUNDS=1
#TRADINGAGENTS_CHECKPOINT_ENABLED=false

# Optional paper execution via Binance Spot Testnet.
# Defaults are dry-run only; set TRADINGAGENTS_ENABLE_ORDER_EXECUTION=true
# only after creating Spot Testnet keys and confirming the planned order.
#TRADINGAGENTS_EXECUTION_MODE=paper
#TRADINGAGENTS_ENABLE_ORDER_EXECUTION=false
#TRADINGAGENTS_MAX_ORDER_USDT=25
#TRADINGAGENTS_BINANCE_DEFAULT_QUOTE_ASSET=USDT
#TRADINGAGENTS_BINANCE_SYMBOL=
#BINANCE_TESTNET_BASE_URL=https://testnet.binance.vision/api
#BINANCE_TESTNET_API_KEY=
#BINANCE_TESTNET_API_SECRET=
